#include<iostream>
using namespace std;

void print4(int n){

    for(int i=1; i<=n; i++){

        // spaces
        for(int j=0; j<n-i; j++){
            cout << " ";
        }

        // alphabets
        char Q = 'A';

        int mid = (2*i-1)/2;

        for(int j=0; j<2*i-1; j++){

            cout << Q;

            if(j < mid)
                Q++;
            else
                Q--;
        }

        cout << endl;
    }
}

int main(){
    int n;
    cin >> n;

    print4(n);
}


