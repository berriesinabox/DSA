#include<iostream>
using namespace std;


void print3(int n){
    for(int i=1;i<=n;i++){
        for(int j=i;j<=n;j++){
            char Q=65+j-i;
            cout << Q;
        }
        cout << endl;
    }
}

int main(){
	int n;
	cin >> n;
	print3(n);
  
}


