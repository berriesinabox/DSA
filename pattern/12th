#include<iostream>
using namespace std;

void print4(int n){

    for(int i=1; i<=n; i++){
        char ch ='E';
        for(int j=0;j<i;j++){
            char fr=ch+j-i+1;
            cout << fr <<" ";
           
        }
        for(int j=0;j<n-i-1;j++){
            cout << " ";
        }
        cout << endl;
    }
}

int main(){
    int n;
    cin >> n;

    print4(n);
}


