#include<iostream>
using namespace std;


void print(int n){
	for(int i=1;i<=n;i++){
	    for(int j=1;j<=i;j++){
	        cout << j;
	    }
	    for(int j=1;j<=(2*n-2*i);j++){
	        cout << " ";
	    }
	    for(int j=1;j<=i;j++){
	        cout << i-j+1;
	    }
	    cout << endl;
	}
}

int main(){
	int n;
	cin >> n;
	print(n);
  
}

